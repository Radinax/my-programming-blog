---
import FormattedDate from "../components/FormattedDate.astro";
import Tag from "../components/Tag.astro";
import { SITE_TITLE } from "../consts";
import BaseLayout from "./BaseLayout.astro";

const { title, description, category, pubDate } = Astro.props;
const uppercaseCategory = category.map(
  (category: string) => category.charAt(0).toUpperCase() + category.slice(1)
);
---

<BaseLayout title={`${SITE_TITLE} | ${title}`} description={description}>
  <article
    class="max-w-fit prose prose-a:text-accent-700 prose-a:font-medium prose-hr:my-8 prose-h1:font-normal prose-h3:font-normal prose-h3:text-xl prose-h2:font-normal prose-h1:mb-0 prose-h1:text-3xl prose-h2:text-2xl prose-code:text-md text-md sm:text-lg text-gray-700 scroller"
  >
    <h1 class="font-bold text-pretty text-center">
      {title}
    </h1>
    <div class="flex flex-row gap-4 text-sm items-center justify-center mt-4">
      <FormattedDate date={pubDate} />—
      <div class="flex flex-row text-xs prose-a:no-underline gap-1">
        {
          uppercaseCategory.map((c: string) => {
            return <Tag>{c}</Tag>;
          })
        }
      </div>
    </div>
    <slot />
  </article>
</BaseLayout>
