---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"a">;

const { href, ...props } = Astro.props;
---

<a
  href={href}
  class="relative z-10 rounded-full bg-accent-50 px-3 py-1 font-medium text-accent-700 ring-1 ring-accent-100 transition hover:bg-accent-100"
  {...props}
>
  <slot />
</a>
